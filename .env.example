# ─────────────────────────────────────────────
# Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────

NODE_ENV=development
API_PORT=3000

# ── Database ──────────────────────────────────
POSTGRES_USER=todo
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=todo_db
DATABASE_URL=postgres://todo:CHANGE_ME_strong_db_password@db:5432/todo_db

# ── Auth ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret

COOKIE_NAME=todo_auth
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
# Use 'strict' in production
COOKIE_SAMESITE=lax

# ── Admin Bootstrap ───────────────────────────
# Created automatically on first start if it does not exist.
# ADMIN_PASSWORD is required — the app will refuse to start without it.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
# Only needed when the bootstrap account has mustChangePassword=true on first login
# ADMIN_NEW_PASSWORD=CHANGE_ME_new_admin_password

# ── OCR Worker ────────────────────────────────
OCR_WORKER_BASE_URL=http://ocr-worker:4000
OCR_ANGLE_CLS_IMAGES=true
OCR_UPSCALE_MIN_DIM=2000
OCR_CONTRAST=1.4

# ── ML Service ────────────────────────────────
ML_SERVICE_URL=http://ml-service:5000
ML_PREFETCH_STRATEGY=DISABLED
